# 이 파일을 복사해 `.streamlit/secrets.toml` 로 저장하고 값을 채우세요.
# 실제 secrets.toml 은 .gitignore 에 의해 git 에 올라가지 않습니다.

# Phase 2: 서버사이드 저장/대시보드는 service_role_key 만 있으면 됩니다.
# service_role 키는 Supabase 대시보드 → Project Settings → API → "service_role" (secret) 에서 복사.
[supabase]
url = "https://peaivwdsxlvenklznfbs.supabase.co"
service_role_key = "YOUR_SERVICE_ROLE_KEY"   # 서버사이드 저장/대시보드용
anon_key = "YOUR_ANON_OR_PUBLISHABLE_KEY"     # 온라인 매칭(브라우저 Realtime)용. Settings→API→anon/publishable

